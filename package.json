{
  "name": "orchestra-multi-agent-ai-framework",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:core": "tsx src/framework/testing/run_tests.ts",
    "test:security": "tsx workspace/security_correctness_regression_tests.ts && tsx workspace/tool_mode_regression_tests.ts && tsx workspace/document_management_regression_tests.ts",
    "test:architecture": "tsx workspace/architecture_queue_regression_tests.ts && tsx workspace/runtime_context_regression_tests.ts && tsx workspace/memory_persistence_regression_tests.ts && tsx workspace/audit_log_regression_tests.ts && tsx workspace/plugin_governance_regression_tests.ts && tsx workspace/claude_audit_regression_tests.ts",
    "test:reliability": "tsx workspace/reliability_gauntlet_tests.ts",
    "test:state-backend": "tsx workspace/state_backend_durability_tests.ts",
    "test:reference": "tsx workspace/reference_code_review_tests.ts",
    "test:projects": "tsx workspace/audit_project_submission_tests.ts",
    "test": "npm run test:core && npm run test:security && npm run test:architecture && npm run test:reliability && npm run test:reference && npm run test:projects",
    "example:code-review": "tsx examples/reference-code-review/run.ts",
    "examples:check": "tsc -p tsconfig.examples.json --noEmit",
    "check": "npm run lint && npm run test && npm run examples:check && npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai": "^3.0.64",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@uiw/react-codemirror": "^4.25.9",
    "@vitejs/plugin-react": "^5.0.4",
    "ai": "^6.0.183",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "natural": "^8.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
