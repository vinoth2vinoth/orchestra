# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI API Key (Optional: For o1, gpt-4o models)
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# Anthropic API Key (Optional: For claude-3.5-sonnet/haiku models)
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# Groq API Key (Optional: For ultra-fast open-source model inference)
GROQ_API_KEY="MY_GROQ_API_KEY"

# Mistral API Key (Optional: For mistral-large-2407 models)
MISTRAL_API_KEY="MY_MISTRAL_API_KEY"

# Cohere API Key (Optional: For command-r models)
COHERE_API_KEY="MY_COHERE_API_KEY"

# DeepSeek API Key (Optional: For deepseek-coder/chat models)
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# OTLP_ENDPOINT: Optional endpoint for OpenTelemetry metrics and traces.
OTLP_ENDPOINT=
