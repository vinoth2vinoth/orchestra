# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI API Key (Optional: For o1, gpt-4o models)
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# Anthropic API Key (Optional: For claude-3.5-sonnet/haiku models)
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# Groq API Key (Optional: For ultra-fast open-source model inference)
GROQ_API_KEY="MY_GROQ_API_KEY"

# Mistral API Key (Optional: For mistral-large-2407 models)
MISTRAL_API_KEY="MY_MISTRAL_API_KEY"

# Cohere API Key (Optional: For command-r models)
COHERE_API_KEY="MY_COHERE_API_KEY"

# DeepSeek API Key (Optional: For deepseek-coder/chat models)
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# GitHub Token for DocArchitect publishing
GITHUB_TOKEN=

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# OTLP_ENDPOINT: Optional endpoint for OpenTelemetry metrics and traces.
# DISABLE_TELEMETRY: Set to 'true' to disable all telemetry emission (memory & network)
OTLP_ENDPOINT=
DISABLE_TELEMETRY=false

# API auth. Required unless ORCHESTRA_DEV_AUTH_BYPASS is explicitly true.
ORCHESTRA_API_TOKEN="CHANGE_ME_LONG_RANDOM_TOKEN"
ORCHESTRA_DEV_AUTH_BYPASS=false

# Production safety. Required when NODE_ENV=production.
ORCHESTRA_ENCRYPTION_KEY="CHANGE_ME_32_BYTE_RANDOM_SECRET"

# Optional integrations and runtime controls.
REDIS_URL=
MAX_CONCURRENCY=8
MCP_ENDPOINT=
LLM_MODEL=gemini-2.5-flash
ORCHESTRA_ENABLE_CODE_SANDBOX=false
ORCHESTRA_ENABLE_STUB_GROUNDEDNESS=false
ORCHESTRA_SEMANTIC_CACHE_TTL_MS=3600000
ORCHESTRA_SEMANTIC_CACHE_MAX_ENTRIES=10000
ORCHESTRA_MEMORY_PERSISTENCE=false
ORCHESTRA_MEMORY_MAX_ENTRIES=5000
ORCHESTRA_QUEUE_VISIBILITY_TIMEOUT_MS=30000
ORCHESTRA_QUEUE_MAX_ATTEMPTS=3

# Tool execution modes: mock (default), live, or disabled. Specific tools override global mode.
ORCHESTRA_TOOL_MODE=mock
ORCHESTRA_TOOL_FETCHURL_MODE=mock
ORCHESTRA_TOOL_HTTPREQUEST_MODE=mock
ORCHESTRA_TOOL_WEBSEARCH_MODE=mock
ORCHESTRA_TOOL_DATABASEQUERY_MODE=mock
ORCHESTRA_TOOL_RAGSEARCH_MODE=mock
ORCHESTRA_TOOL_EXECUTESHELLCOMMAND_MODE=mock
ORCHESTRA_ENABLE_SHELL_TOOL=false

# Enables demo/experimental plugins with simulated or stochastic behavior.
ORCHESTRA_ENABLE_EXPERIMENTAL_PLUGINS=false
